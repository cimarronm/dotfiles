alias ..='cd ..'
alias ...='cd ../..'
alias diff='diff --color=auto'
alias egrep='egrep --color=auto'
alias g='git'
alias ga='git add'
alias gb='git branch'
alias gc='git commit'
alias gco='git checkout'
alias gd='git diff'
alias gl='git log --oneline --graph'
alias gp='git push'
alias gpl='git pull'
alias gs='git status'
alias grep='grep --color=auto'
alias h='history'
alias ll='ls -al'
alias less='less -iR'
alias ls='ls -F --color=auto'
alias mkdir='mkdir -p'
alias mx='chmod a+x'
alias path='echo $PATH | tr ":" "\n"'
alias rg='rg --hidden'
alias rgi='rg -i'
alias weather='curl wttr.in'
